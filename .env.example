# Flight Scanner configuration.
# This app needs NO API keys or secrets (flight data is scraped from Google
# Flights with no auth). The only setting is the demo-data toggle below.
# Copy to `.env` (which is gitignored) to override.

# 0 = attempt live Google Flights (default; falls back to demo data on failure)
# 1 = force full-detail demo/mock data (works fully offline)
FLIGHT_SCANNER_MOCK=0

# Local bind defaults. Override FLIGHT_SCANNER_PORT if 8420 is already in use.
FLIGHT_SCANNER_BIND_ADDR=127.0.0.1
FLIGHT_SCANNER_PORT=8420
