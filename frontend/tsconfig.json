{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "types": ["vitest/globals", "@testing-library/jest-dom"]
  },
  "include": ["src", "vendor/pandora-components/web/src"],
  "exclude": [
    "vendor/pandora-components/web/src/charts.ts",
    "vendor/pandora-components/web/src/components/BarChartCard.tsx",
    "vendor/pandora-components/web/src/components/Donut.tsx",
    "vendor/pandora-components/web/src/components/TimeSeriesChart.tsx"
  ]
}
